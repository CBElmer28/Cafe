# Configuración básica de n8n
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=America/Bogota
N8N_USER_FOLDER=/home/node/.n8n
NODES_EXCLUDE=[]
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all

# Credenciales de ngrok
# Consigue tu token de autenticación gratuito registrándote en ngrok.com
NGROK_AUTHTOKEN=TU_NGROK_AUTHTOKEN_AQUI

# Reemplazar con la URL HTTPS de tu túnel ngrok local (ej: https://xxxx.ngrok-free.dev)
# n8n necesita esta variable para registrar correctamente los webhooks en GitHub.
WEBHOOK_URL=https://TU_SUBDOMINIO.ngrok-free.dev
